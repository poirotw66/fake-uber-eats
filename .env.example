# Uber Eats account (OTP / verification code login — no password required)
UBEREATS_EMAIL=your@email.com

# Leave empty for Taiwan OTP login; only set if your account still uses password
UBEREATS_PASSWORD=

# First login: open browser and complete OTP manually (recommended)
UBEREATS_MANUAL_LOGIN=1
UBEREATS_HEADLESS=0
UBEREATS_LOGIN_TIMEOUT=300
UBEREATS_FRESH_LOGIN=1
# Optional: override auth entry (default https://auth.uber.com/v2/?next_url=...)
# UBEREATS_AUTH_URL=https://auth.uber.com/v2/

# Optional overrides
UBEREATS_ADDRESS=國泰金融中心
UBEREATS_LAT=25.0382477
UBEREATS_LNG=121.5691055
UBEREATS_MAX_STORES=12
UBEREATS_MAX_MENU_ITEMS=16

# Menu-only parallel scrape (./scripts/scrape_menus_only.sh)
UBEREATS_MENU_WORKERS=4
UBEREATS_API_INTERVAL=0.6
UBEREATS_CHECKPOINT_EVERY=5
UBEREATS_RATE_LIMIT_WAIT=25
